{
  "name": "fcp-sfd-comms",
  "version": "0.20.1",
  "description": "Comms Service for Single Front Door",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "docker:build": "docker compose build",
    "docker:dev": "docker compose up",
    "docker:dev:d": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:stop:v": "docker compose down -v",
    "docker:test": "docker compose -p fcp-sfd-comms-test down && docker compose -f compose.yaml -f compose.test.yaml -p fcp-sfd-comms-test run --build --rm 'fcp-sfd-comms'",
    "docker:test:watch": "docker compose -p fcp-sfd-comms-test down && docker compose -f compose.yaml -f compose.test.yaml -f compose.test.watch.yaml -p fcp-sfd-comms-test run --build --rm 'fcp-sfd-comms'",
    "docker:debug": "docker compose -f compose.yaml -f compose.debug.yaml -p 'fcp-sfd-comms' up",
    "test": "rm -rf ./coverage/** && vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "npx eslint . --ext .js",
    "lint:fix": "npx eslint . --ext .js --fix",
    "start": "node --experimental-vm-modules src/index.js",
    "start:watch": "nodemon --watch src --exec 'node --experimental-vm-modules --inspect=0.0.0.0 src/index.js'",
    "start:debug": "nodemon --watch src --exec 'node --experimental-vm-modules --inspect-brk=0.0.0.0 src/index.js'",
    "sonar": "node scripts/sonar-scan.js"
  },
  "author": "Defra DDTS",
  "contributors": [
    "Fay Toward <fay.toward@defra.gov.uk>",
    "Shaun Fitzsimons <shaun.fitzsimmons@defra.gov.uk>",
    "Rana Salem <rana.salem@defra.gov.uk>",
    "Adam Kay <adam.kay@defra.gov.uk>"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-sns": "3.974.0",
    "@aws-sdk/client-sqs": "3.974.0",
    "@defra/hapi-tracing": "1.0.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.8",
    "aws-embedded-metrics": "4.2.0",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "cron": "4.3.0",
    "date-fns": "4.1.0",
    "global-agent": "3.0.0",
    "hapi-pino": "12.1.0",
    "hapi-pulse": "3.0.1",
    "http-status-codes": "2.3.0",
    "https-proxy-agent": "7.0.5",
    "joi": "17.13.3",
    "lodash": "4.18.1",
    "mongo-locks": "3.0.2",
    "mongodb": "6.10.0",
    "node-fetch": "3.3.2",
    "notifications-node-client": "8.3.2",
    "pino": "9.5.0",
    "pino-pretty": "13.0.0",
    "semaphore": "1.1.0",
    "sqs-consumer": "11.6.0",
    "undici": "6.24.1"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "4.3.2",
    "@types/convict": "6.1.6",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.23",
    "@types/node": "22.13.4",
    "@types/webpack-assets-manifest": "5.1.4",
    "@vitest/coverage-v8": "3.1.2",
    "autoprefixer": "10.4.20",
    "dotenv": "17.3.1",
    "eslint": "9.39.4",
    "jest": "29.7.0",
    "jest-fetch-mock": "3.0.3",
    "neostandard": "0.13.0",
    "nodemon": "3.1.7",
    "npm-run-all": "4.1.5",
    "vitest": "3.1.2"
  },
  "overrides": {
    "form-data": "4.0.4",
    "axios": "1.15.2",
    "follow-redirects": "1.16.0",
    "fast-xml-builder": "1.1.5",
    "@hapi/content": "6.0.1"
  }
}
